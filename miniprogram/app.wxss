page {
  height: 100%;
  color: #172033;
  background: #f6f7f8;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

view,
text,
scroll-view,
input,
button {
  box-sizing: border-box;
}

button {
  padding: 0;
  margin: 0;
  line-height: normal;
  background: transparent;
}

button::after {
  border: 0;
}
