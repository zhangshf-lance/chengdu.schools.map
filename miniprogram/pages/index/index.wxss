.page {
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
}

.map {
  width: 100%;
  height: 100%;
}

.topbar {
  position: absolute;
  top: 24rpx;
  left: 24rpx;
  right: 24rpx;
  z-index: 5;
  min-height: 88rpx;
  padding: 14rpx 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  border: 1rpx solid rgba(17, 24, 39, 0.08);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 10rpx 30rpx rgba(17, 24, 39, 0.10);
}

.region-picker {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.region-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #9f2b18;
}

.region-count {
  font-size: 22rpx;
  color: #6b7280;
}

.legend {
  display: flex;
  gap: 14rpx;
  font-size: 22rpx;
  color: #4b5563;
  white-space: nowrap;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.dot,
.school-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  display: inline-block;
}

.primary,
.school-dot.primary {
  background: #2563eb;
}

.middle,
.school-dot.middle {
  background: #059669;
}

.filter-panel {
  position: absolute;
  top: 126rpx;
  left: 24rpx;
  right: 24rpx;
  z-index: 5;
  padding: 14rpx;
  border: 1rpx solid rgba(17, 24, 39, 0.08);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 8rpx 24rpx rgba(17, 24, 39, 0.08);
}

.region-strip {
  width: 100%;
  white-space: nowrap;
}

.region-chip-row {
  display: inline-flex;
  gap: 10rpx;
  padding-bottom: 12rpx;
}

.region-chip {
  height: 52rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  border: 1rpx solid #d9dee8;
  color: #374151;
  background: #f8fafc;
  font-size: 24rpx;
}

.region-chip.active {
  color: #ffffff;
  border-color: #9f2b18;
  background: #9f2b18;
}

.search-row {
  position: relative;
  height: 64rpx;
}

.search-input {
  width: 100%;
  height: 64rpx;
  padding: 0 70rpx 0 22rpx;
  border: 1rpx solid #d9dee8;
  border-radius: 12rpx;
  background: #f8fafc;
  font-size: 26rpx;
}

.clear-btn {
  position: absolute;
  top: 0;
  right: 0;
  width: 64rpx;
  height: 64rpx;
  color: #6b7280;
  font-size: 38rpx;
}

.type-tabs {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin-top: 12rpx;
}

.type-tab {
  height: 58rpx;
  border: 1rpx solid #d9dee8;
  border-radius: 12rpx;
  color: #4b5563;
  background: #ffffff;
  font-size: 25rpx;
  font-weight: 600;
}

.type-tab.active {
  color: #ffffff;
}

.type-tab.active.all {
  border-color: #9f2b18;
  background: #9f2b18;
}

.type-tab.active.primary {
  border-color: #2563eb;
  background: #2563eb;
}

.type-tab.active.middle {
  border-color: #059669;
  background: #059669;
}

.bottom-sheet {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  z-index: 5;
  height: 36vh;
  min-height: 420rpx;
  display: flex;
  flex-direction: column;
  border: 1rpx solid rgba(17, 24, 39, 0.08);
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -8rpx 34rpx rgba(17, 24, 39, 0.12);
  overflow: hidden;
}

.sheet-head {
  padding: 18rpx 22rpx 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #eef1f5;
}

.sheet-title {
  font-size: 28rpx;
  font-weight: 700;
}

.sheet-subtitle {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #6b7280;
}

.source-pill {
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  color: #92400e;
  background: #fff2c7;
  font-size: 21rpx;
}

.school-list {
  flex: 1;
  min-height: 0;
}

.school-item {
  min-height: 96rpx;
  padding: 16rpx 22rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  border-bottom: 1rpx solid #f1f4f8;
}

.school-item.active {
  background: #fff7ed;
}

.school-main {
  min-width: 0;
  flex: 1;
}

.school-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 27rpx;
  font-weight: 600;
  color: #172033;
}

.school-meta {
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 22rpx;
  color: #6b7280;
}

.empty {
  padding: 42rpx;
  text-align: center;
  color: #8a94a6;
  font-size: 25rpx;
}

.detail-mask {
  position: absolute;
  inset: 0;
  z-index: 9;
  display: flex;
  align-items: flex-end;
  background: rgba(17, 24, 39, 0.18);
}

.detail-card {
  width: 100%;
  max-height: 72vh;
  padding: 26rpx 28rpx calc(28rpx + env(safe-area-inset-bottom));
  border-radius: 26rpx 26rpx 0 0;
  background: #ffffff;
  box-shadow: 0 -14rpx 38rpx rgba(17, 24, 39, 0.18);
}

.detail-head {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 22rpx;
}

.detail-title {
  font-size: 34rpx;
  line-height: 1.25;
  font-weight: 800;
  color: #172033;
}

.detail-meta {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.detail-close {
  flex: 0 0 auto;
  width: 54rpx;
  height: 54rpx;
  color: #6b7280;
  font-size: 42rpx;
}

.section-title {
  margin: 18rpx 0 10rpx;
  color: #374151;
  font-size: 25rpx;
  font-weight: 800;
}

.group-block {
  padding: 14rpx;
  margin-bottom: 12rpx;
  border-radius: 14rpx;
  background: #f8fafc;
}

.group-name {
  margin-bottom: 10rpx;
  color: #9f2b18;
  font-size: 24rpx;
  font-weight: 700;
}

.group-links {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.link-chip {
  max-width: 100%;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  color: #1d4ed8;
  background: #eff6ff;
  font-size: 22rpx;
}

.zone-text {
  max-height: 220rpx;
  padding: 16rpx;
  border-radius: 14rpx;
  color: #374151;
  background: #f8fafc;
  font-size: 25rpx;
  line-height: 1.65;
}

.source-box {
  margin-top: 16rpx;
  color: #6b7280;
  font-size: 22rpx;
  line-height: 1.5;
}
